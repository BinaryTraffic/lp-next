# 開発専用のローカル置き場（推奨: 大容量・下書きは Git 管理外）
current/dev/**/_local/*
!current/dev/**/_local/README.md

# 作業データ・生成物（current 配下）
current/lp_reverse_cms/data/*
!current/lp_reverse_cms/data/.gitkeep
current/lp_reverse_cms/output/*
!current/lp_reverse_cms/output/.gitkeep

# 旧パス（過去の clone 向けに残す場合）
lp_reverse_cms/data/*
!lp_reverse_cms/data/.gitkeep
lp_reverse_cms/output/*
!lp_reverse_cms/output/.gitkeep

# OS・エディタ
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# 任意: Cursor ローカル（チームで共有する場合はこの行を削除）
.cursor/

# シークレット（VM 上のみ配置）
current/lp_reverse_cms/.env

# フォント（.gitkeep のみ管理。実体は VM に配置またはパッケージからコピー）
current/lp_reverse_cms/fonts/*.ttc
current/lp_reverse_cms/fonts/*.ttf
current/lp_reverse_cms/fonts/*.otf

# ログ・一時ファイル
*.log
php_errors.log
