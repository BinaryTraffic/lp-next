# Site Reverse CMS — root .htaccess

# Deny access to PHP lib files directly
<FilesMatch "^(LpFetcher|LpAnalyzer|LpMapper|LpGenerator|LpDomScriptCleanup|GoogleAuth|UserRegistry|session_bootstrap|LpCloneImagePack|cms_editor_auth)\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Deny access to template files directly
<FilesMatch "\.(json|html)$">
    <If "%{REQUEST_URI} =~ m|/data/|">
        Order Deny,Allow
        Deny from all
    </If>
</FilesMatch>

# UTF-8（.md が charset なしで配信されブラウザが誤判定する対策）
AddDefaultCharset UTF-8
<IfModule mod_mime.c>
    AddCharset utf-8 .md
</IfModule>

# Enable URL rewriting (optional, for clean URLs)
Options -Indexes
