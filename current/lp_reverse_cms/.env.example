# LP Reverse CMS — コピーして .env にリネーム（.env は Git 管理外）
# VM 上: chmod 600 .env
#
# OpenAI Images API（lp_ai_image_review.html のプロキシが使用）
# 平文キー。リポジトリに載せないこと。より安全にする場合は GCP Secret Manager 等で
# プロセス環境変数 OPENAI_API_KEY を注入し、このファイルは使わない運用でもよい。
OPENAI_API_KEY=

# 1 にすると、サーバーに OPENAI_API_KEY が無い場合でも POST の api_key を拒否する（厳格モード）
# OPENAI_DENY_CLIENT_KEY=1
