# LP Reverse CMS — このファイルをコピーして lp_reverse_cms/.env にリネーム（.env は Git 管理外）
# 例: /home/lp-next/current/lp_reverse_cms/.env
# VM 上: chmod 600 .env
# 読込: 全 store/*.php が lib/env_load.php 経由でこのファイルを参照（LP_REVERSE_ENV_PATH で別パスも可）
#
# OpenAI Images API（lp_ai_image_review.html のプロキシが使用）
# 平文キー。リポジトリに載せないこと。より安全にする場合は GCP Secret Manager 等で
# プロセス環境変数 OPENAI_API_KEY を注入し、このファイルは使わない運用でもよい。
OPENAI_API_KEY=

# 1 にすると、サーバーに OPENAI_API_KEY が無い場合でも POST の api_key を拒否する（厳格モード）
# OPENAI_DENY_CLIENT_KEY=1

# image_composite.php — 日本語フォント（書き出しの文字描画）
# 探索順: IMAGE_COMPOSITE_FONT* → lp_reverse_cms/fonts/（同梱可）→ 代表的な /usr/share/fonts/... → fc-list :lang=ja
# open_basedir 内に /usr/share/fonts が無いと、システムに Noto があっても PHP からは読めません。そのときは fonts/ にコピーして下記の絶対パスを指定。
# サーバに無い場合: sudo apt install fonts-noto-cjk（Debian/Ubuntu）
# または lp_reverse_cms/fonts/ に NotoSansCJK-Regular.ttc / NotoSansCJK-Bold.ttc をコピー（.env 省略でも可）
# IMAGE_COMPOSITE_FONT=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
# IMAGE_COMPOSITE_FONT_BOLD=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc

# Hugging Face Inference API（hf_image_proxy.php — FLUX 等の text-to-image）
# https://huggingface.co/settings/tokens
# HUGGINGFACE_API_TOKEN=hf_...
# または
# HF_TOKEN=hf_...
# 任意: モデルID（既定 black-forest-labs/FLUX.1-schnell）
# HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
# 1 にすると POST の api_key を拒否（本番推奨）
# HF_DENY_CLIENT_KEY=1

# Claude Vision（claude_image_analyze.php）
# ANTHROPIC_API_KEY=
# ANTHROPIC_DENY_CLIENT_KEY=1

# API 利用ログ（lib/api_usage_log.php）— 1 リクエストごとに data/api_usage_events.jsonl へ追記し、
# .env の変数名（OPENAI_API_KEY / ANTHROPIC_API_KEY / HUGGINGFACE_API_TOKEN / HF_TOKEN）別に data/api_usage_totals.json を更新。
# 概算 USD は公表単価の目安（未設定時はコード内デフォルト）。請求額の保証ではない。
# LP_USAGE_OPENAI_DALLE3_1024_USD=0.04
# LP_USAGE_OPENAI_DALLE3_WIDE_USD=0.08
# LP_USAGE_OPENAI_DALLE2_1024_USD=0.02
# LP_USAGE_ANTHROPIC_INPUT_PER_MTOK_USD=3
# LP_USAGE_ANTHROPIC_OUTPUT_PER_MTOK_USD=15
# LP_USAGE_HF_USD_PER_CALL=0
