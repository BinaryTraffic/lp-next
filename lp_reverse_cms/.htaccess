# LP Reverse CMS — root .htaccess

# Deny access to PHP lib files directly
<FilesMatch "^(LpFetcher|LpAnalyzer|LpMapper|LpGenerator)\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Deny access to template files directly
<FilesMatch "\.(json|html)$">
    <If "%{REQUEST_URI} =~ m|/data/|">
        Order Deny,Allow
        Deny from all
    </If>
</FilesMatch>

# UTF-8 default charset
AddDefaultCharset UTF-8

# /docs/ だけ DirectoryIndex 無しで 403 になりやすいので PHP に寄せる
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^docs/?$ documents.php [L]
</IfModule>

# Enable URL rewriting (optional, for clean URLs)
Options -Indexes
